{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*' --env='VITE_*'",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.0.1",
    "@clerk/react": "^6.0.1",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.2.1"
  }
}
