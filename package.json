{
  "name": "clawpify",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "test:backend": "cd backend && SQLX_OFFLINE=true cargo test --lib audit::",
    "test:backend:integration": "cd backend && cargo test --test llm_citation_test -- --ignored",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*' --env='VITE_*'",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.0.1",
    "@clerk/react": "^6.0.1",
    "@mendable/firecrawl-js": "^4.15.4",
    "chart.js": "^4.4.0",
    "framer-motion": "^12.36.0",
    "react": "^19",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.2.1"
  }
}
