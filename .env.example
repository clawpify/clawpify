# Clerk (create app at https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_...
BUN_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional
RUST_API_URL=http://127.0.0.1:3000
PORT=3001

# Railway (Bun service):
# - Prefer private Rust URL for server-side proxy (avoids pointing at this Bun app’s *.up.railway.app URL):
#   RUST_API_URL_INTERNAL=http://<YourRustServiceName>.railway.internal:<RustPORT>
# - If unset, Bun uses RUST_API_URL (must be the Rust service base URL, not this Bun app’s public hostname).
# - Health check (Railway dashboard): GET /healthz — do NOT use /api/health (that proxies to Rust).
# If RUST_API_URL’s hostname equals this Bun service’s public host, startup fails — proxy loop.
# ALLOW_RUST_PROXY_SAME_HOST=1 bypasses that check (unsafe).
# BUN_SERVICE_URL=
#
# Upstream fetch timeout in ms (default 25000).
# RUST_PROXY_TIMEOUT_MS=25000

# Optional: public API origin for browser-side fetch (e.g. waitlist). Empty = same-origin `/api/*` on this Bun app.
# BUN_PUBLIC_API_BASE=https://your-rust-api.example.com

# Optional: Firecrawl for website scraping (falls back to HTTP if unset)
# FIRECRAWL_API_KEY=fc-...

# CORS: origins allowed to call the Rust backend (backend reads this)
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
