# Clerk (create app at https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_...
BUN_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional
RUST_API_URL=http://127.0.0.1:3000
PORT=3001

# Railway: set RUST_API_URL to the Rust service private URL (http://<service>.railway.internal:<PORT>), never this Bun app's public URL.
# Optional: enables fatal loop detection vs RUST_API_URL (your Bun service public origin, https://...)
# BUN_SERVICE_URL=
# ALLOW_RUST_PROXY_SAME_ORIGIN=1

# Liveness without proxying Rust: GET /healthz (use for Railway health checks on the Bun service)

# Optional: browser uses this origin for /api/* (no trailing slash). Same-origin when unset.
# Use if the SPA is hosted separately from the Bun server, or to call the Rust API URL directly
# (then add your site origin to CORS_ALLOWED_ORIGINS on the Rust backend).
# BUN_PUBLIC_API_BASE=https://your-rust-api.example.com

# Optional: Firecrawl for website scraping (falls back to HTTP if unset)
# FIRECRAWL_API_KEY=fc-...

# CORS: origins allowed to call the Rust backend (backend reads this)
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
