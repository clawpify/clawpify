# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/clawpify

# Required for ChatGPT citation (generate prompts, run citation checks)
OPENAI_API_KEY=sk-...

# Optional: OpenAI model overrides (defaults: gpt-4o-mini for prompts, gpt-4o for citation search)
# OPENAI_PROMPT_MODEL=gpt-4o-mini
# OPENAI_CITATION_MODEL=gpt-4o

# Optional: Restrict scraping to these hosts (pipe-separated). When unset, all URLs allowed.
# Example for Shopify: myshopify.com|shopify.com
# TRUSTED_HOSTS=myshopify.com|shopify.com

# CORS: origins allowed to call this API (comma-separated)
# Production: set to your app domain, e.g. https://app.clawpify.com
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
