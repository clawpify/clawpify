# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/clawpify

# S3 (Railway bucket): required for POST /api/v1/s3/objects upload and GET redirect; missing → 503
# BUCKET_ENDPOINT_URL=
# BUCKET_REGION=
# BUCKET_NAME=
# BUCKET_ID=
# BUCKET_SECRET=
# BUCKET_FORCE_PATH_STYLE=1

# Optional: Restrict scraping to these hosts (pipe-separated). When unset, all URLs allowed.
# Example for Shopify: myshopify.com|shopify.com
# TRUSTED_HOSTS=myshopify.com|shopify.com

# CORS: origins allowed to call this API (comma-separated)
# Production: set to your app domain, e.g. https://app.clawpify.com
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# LLM: required for POST /api/llm/agents
# OPENAI_API_KEY=
# OPENAI_LLM_MODEL=gpt-5.2

# Shopify OAuth — use the same redirect URL in Partner Dashboard and here.
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_OAUTH_REDIRECT_URL=https://example.com/api/reseller/oauth/shopify/callback
# OAUTH_STATE_SECRET=long_random_string_min_16_chars
# CHANNEL_ENCRYPTION_KEY=64_hex_chars
